# Default behavior: enforce LF line endings for all text files automatically
* text=auto eol=lf

# Scala / SBT source files
*.scala        text eol=lf
*.sbt          text eol=lf

# Documentation and configuration files
*.md           text eol=lf
*.txt          text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.conf         text eol=lf
*.json         text eol=lf
.editorconfig  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Explicit binary declarations to prevent line ending corruption
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.svg          text eol=lf
